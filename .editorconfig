root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
insert_final_newline = true
trim_trailing_whitespace = true

[*.{kt,kts,java}]
indent_size = 4
max_line_length = 120
ktlint_standard_package-name = disabled

[*.md]
trim_trailing_whitespace = false

[Makefile]
indent_style = tab
